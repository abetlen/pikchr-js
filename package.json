{
  "name": "pikchr-js",
  "version": "0.1.2",
  "description": "Pikchr diagram markup language ported to Javascript",
  "homepage": "https://github.com/abetlen/pikchr-js#readme",
  "repository": "github:abetlen/pikchr-js",
  "main": "index.js",
  "module": "index.mjs",
  "unpkg": "./pikchr.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "unpkg": "./pikchr.js",
      "import": {
        "types": "./index.d.mts",
        "default": "./index.mjs"
      },
      "require": {
        "types": "./index.d.ts",
        "default": "./index.js"
      },
      "default": "./index.js"
    },
    "./index": {
      "import": {
        "types": "./index.d.mts",
        "default": "./index.mjs"
      },
      "require": {
        "types": "./index.d.ts",
        "default": "./index.js"
      },
      "default": "./index.js"
    },
    "./index.js": "./index.js",
    "./index.mjs": "./index.mjs",
    "./pikchr": "./pikchr.js",
    "./pikchr.js": "./pikchr.js",
    "./package.json": "./package.json"
  },
  "files": [
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "examples/pikchr-to-svg.svg",
    "index.d.mts",
    "index.d.ts",
    "index.js",
    "index.mjs",
    "pikchr.js"
  ],
  "scripts": {
    "build:emscripten": "docker run --rm -v $(pwd):/src -u $(id -u):$(id -g) emscripten/emsdk:5.0.7 ./build.sh",
    "build": "npm run build:emscripten",
    "test": "ava"
  },
  "author": "Andrei Betlen",
  "license": "0BSD",
  "devDependencies": {
    "ava": "^3.13.0"
  }
}
