{
  "name": "pikchr-js",
  "version": "0.1.4",
  "description": "Pikchr diagram markup language ported to Javascript",
  "homepage": "https://github.com/abetlen/pikchr-js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abetlen/pikchr-js.git"
  },
  "main": "index.js",
  "module": "index.mjs",
  "bin": {
    "pikchr": "./bin/pikchr.js",
    "pikchr-js": "./bin/pikchr.js"
  },
  "unpkg": "./pikchr.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "unpkg": "./pikchr.js",
      "import": {
        "types": "./index.d.mts",
        "default": "./index.mjs"
      },
      "require": {
        "types": "./index.d.ts",
        "default": "./index.js"
      },
      "default": "./index.js"
    },
    "./index": {
      "import": {
        "types": "./index.d.mts",
        "default": "./index.mjs"
      },
      "require": {
        "types": "./index.d.ts",
        "default": "./index.js"
      },
      "default": "./index.js"
    },
    "./index.js": "./index.js",
    "./index.mjs": "./index.mjs",
    "./pikchr": "./pikchr.js",
    "./pikchr.js": "./pikchr.js",
    "./package.json": "./package.json"
  },
  "files": [
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "examples/pikchr-to-svg.svg",
    "bin/pikchr.js",
    "index.d.mts",
    "index.d.ts",
    "index.js",
    "index.mjs",
    "pikchr.js"
  ],
  "scripts": {
    "build:emscripten": "docker run --rm -v $(pwd):/src -u $(id -u):$(id -g) emscripten/emsdk:5.0.7 ./build.sh",
    "build": "npm run build:emscripten",
    "prepublishOnly": "npm test",
    "site:build": "rm -rf _site && mkdir -p _site && cp -R site/. _site/ && cp pikchr.js _site/pikchr.js",
    "test": "ava"
  },
  "author": "Andrei Betlen",
  "license": "0BSD",
  "devDependencies": {
    "ava": "^3.13.0"
  }
}
